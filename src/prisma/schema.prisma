// MeDoc - Praxismanagementsystem für Zahnarztpraxen
// Datenbankschema basierend auf V-Modell Phase 1-4

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// AUTH & PERSONAL
// ============================================================

enum Rolle {
  ARZT
  REZEPTION
  STEUERBERATER
  PHARMABERATER
}

model Personal {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  passwort         String    // bcrypt-hashed
  rolle            Rolle     @default(REZEPTION)
  taetigkeitsbereich String?
  fachrichtung     String?
  telefon          String?
  verfuegbar       Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relationen
  termine          Termin[]  @relation("ArztTermine")
  auditLogs        AuditLog[]
}

// ============================================================
// PATIENT
// ============================================================

enum Geschlecht {
  MAENNLICH
  WEIBLICH
  DIVERS
}

enum PatientStatus {
  NEU
  AKTIV
  VALIDIERT
  READONLY
}

model Patient {
  id                  String        @id @default(cuid())
  name                String
  geburtsdatum        DateTime
  geschlecht          Geschlecht
  versicherungsnummer String
  telefon             String?
  email               String?
  adresse             String?
  status              PatientStatus @default(NEU)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // Relationen
  akte                Patientenakte?
  termine             Termin[]
  zahlungen           Zahlung[]
  anamnesebogen       Anamnesebogen?
}

// ============================================================
// PATIENTENAKTE
// ============================================================

enum AkteStatus {
  NEU
  IN_BEARBEITUNG
  VALIDIERT
  READONLY
}

model Patientenakte {
  id                String      @id @default(cuid())
  patientId         String      @unique
  status            AkteStatus  @default(NEU)
  behandlungsverlauf String?
  diagnose          String?
  befunde           String?
  notizen           String?
  validiertVon      String?
  validiertAm       DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relationen
  patient           Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  untersuchungen    Untersuchung[]
  behandlungen      Behandlung[]
  dokumente         Dokument[]
  zahnbefunde       Zahnbefund[]
}

// ============================================================
// TERMIN
// ============================================================

enum TerminArt {
  UNTERSUCHUNG
  BEHANDLUNG
  NOTFALL
}

enum TerminStatus {
  ANGEFRAGT
  BESTAETIGT
  DURCHGEFUEHRT
  ABGESCHLOSSEN
  STORNIERT
}

model Termin {
  id            String       @id @default(cuid())
  datum         DateTime
  uhrzeit       String       // "HH:MM"
  art           TerminArt
  status        TerminStatus @default(ANGEFRAGT)
  beschwerden   String?
  patientId     String
  arztId        String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Relationen
  patient       Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  arzt          Personal     @relation("ArztTermine", fields: [arztId], references: [id])

  @@unique([datum, uhrzeit, arztId]) // Konfliktprüfung
}

model BlockierteZeit {
  id            String   @id @default(cuid())
  arztId        String
  datum         DateTime
  vonUhrzeit    String?  // null = ganzer Tag
  bisUhrzeit    String?
  grund         String?
  createdAt     DateTime @default(now())
}

// ============================================================
// ANAMNESEBOGEN
// ============================================================

model Anamnesebogen {
  id              String   @id @default(cuid())
  patientId       String   @unique
  antworten       Json     // { frage: antwort }
  unterschrieben  Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

// ============================================================
// UNTERSUCHUNG & BEHANDLUNG
// ============================================================

model Untersuchung {
  id                    String        @id @default(cuid())
  akteId                String
  beschwerden           String
  untersuchungsergebnisse String?
  diagnose              String?
  bildmaterial          String?       // Dateipfad/URL
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  akte                  Patientenakte @relation(fields: [akteId], references: [id], onDelete: Cascade)
}

model Behandlung {
  id              String        @id @default(cuid())
  akteId          String
  behandlungsart  String
  verlauf         String?
  materialien     String?
  dokumentation   String?
  erfolg          Boolean?
  abbruchgrund    String?
  leistungId      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  akte            Patientenakte @relation(fields: [akteId], references: [id], onDelete: Cascade)
  leistung        Leistung?     @relation(fields: [leistungId], references: [id])
}

// ============================================================
// ZAHNSCHEMA
// ============================================================

model Zahnbefund {
  id          String        @id @default(cuid())
  akteId      String
  zahnNummer  Int           // FDI-Nummerierung (11-48)
  befund      String        // gesund, karioes, fehlend, etc.
  diagnose    String?
  behandlung  String?
  notizen     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  akte        Patientenakte @relation(fields: [akteId], references: [id], onDelete: Cascade)

  @@unique([akteId, zahnNummer])
}

// ============================================================
// DOKUMENTE
// ============================================================

enum DokumentTyp {
  ROENTGEN
  LABORBEFUND
  REZEPT
  ATTEST
  QUITTUNG
  SONSTIGES
}

model Dokument {
  id            String        @id @default(cuid())
  akteId        String
  typ           DokumentTyp
  titel         String
  dateiPfad     String?
  referenzNr    String?
  tags          String?
  createdAt     DateTime      @default(now())

  akte          Patientenakte @relation(fields: [akteId], references: [id], onDelete: Cascade)
}

// ============================================================
// FINANZEN
// ============================================================

enum ZahlungStatus {
  BEZAHLT
  OFFEN
  STORNIERT
}

enum ZahlungsArt {
  BAR
  KARTE
  UEBERWEISUNG
}

model Zahlung {
  id            String        @id @default(cuid())
  patientId     String
  betrag        Float
  zahlungsart   ZahlungsArt
  status        ZahlungStatus @default(OFFEN)
  beschreibung  String?
  leistungId    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  patient       Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  leistung      Leistung?     @relation(fields: [leistungId], references: [id])
}

model Finanzdokument {
  id          String   @id @default(cuid())
  typ         String   // Einnahme, Ausgabe
  betrag      Float
  kategorie   String?
  beschreibung String?
  zeitraum    DateTime
  createdAt   DateTime @default(now())
}

// ============================================================
// LEISTUNGEN
// ============================================================

model Leistung {
  id          String       @id @default(cuid())
  name        String
  kategorie   String
  preis       Float
  aktiv       Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  behandlungen Behandlung[]
  zahlungen    Zahlung[]
}

// ============================================================
// PRODUKTE & BESTELLUNGEN
// ============================================================

enum LieferStatus {
  BESTELLT
  GELIEFERT
  STORNIERT
}

model Produkt {
  id            String       @id @default(cuid())
  name          String
  lieferant     String
  menge         Int          @default(0)
  lieferstatus  LieferStatus @default(BESTELLT)
  hersteller    String?
  preis         Float?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model ExternerPartner {
  id                String  @id @default(cuid())
  typ               String  // STEUERBERATER, PHARMABERATER
  firmenname        String?
  personenname      String
  taetigkeitsbereich String?
  email             String?
  telefon           String?
  verfuegbar        Boolean @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  action      String   // CREATE, UPDATE, DELETE, LOGIN, etc.
  entity      String   // Patient, Termin, Behandlung, etc.
  entityId    String?
  details     String?
  timestamp   DateTime @default(now())

  user        Personal @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([timestamp])
}
